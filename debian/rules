#!/usr/bin/make -f

export PYBUILD_NAME=ailab

# Derive upstream version from the changelog so setuptools-scm gets the right
# version when building from a source tarball (no git history available).
# e.g. "0.1.0-1~noble1" → "0.1.0"
export SETUPTOOLS_SCM_PRETEND_VERSION := $(shell dpkg-parsechangelog -SVersion | sed 's/-[^-]*$$//')

%:
	dh $@ --buildsystem=pybuild --with python3

override_dh_auto_install:
	dh_auto_install
	pip3 install \
		--target=debian/ailab/usr/lib/python3/dist-packages/ailab/_vendor \
		--no-deps \
		--no-index \
		--find-links=vendor \
		"pylxd>=2.4.0"

override_dh_auto_test:
